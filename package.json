{
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "@babel/core": ">=7.29.6 <8",
      "brace-expansion@5": ">=5.0.6 <6",
      "esbuild": ">=0.28.1 <0.29",
      "fast-uri": ">=3.1.2 <4",
      "hono": ">=4.12.25 <5",
      "@hono/node-server": ">=1.19.13 <2",
      "ip-address": ">=10.1.1 <11",
      "js-yaml": ">=4.2.0 <5",
      "postcss": ">=8.5.10 <9",
      "qs": ">=6.15.2 <7",
      "tar": ">=7.5.16 <8"
    }
  },
  "scripts": {
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter web typecheck",
    "validate:usecases": "node scripts/validate-use-cases.mjs",
    "db:generate": "pnpm --filter web db:generate",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:deploy": "pnpm --filter web db:deploy",
    "db:push": "pnpm --filter web db:push",
    "db:studio": "pnpm --filter web db:studio"
  }
}
