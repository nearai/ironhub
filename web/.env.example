# Generate every secret with a strong random value. Never deploy the placeholders.
DATABASE_URL=postgres://user:password@localhost:5432/ironhub

# Session signing secret. generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DISABLE_ACCOUNT_ROUTE=false
NEXT_PUBLIC_DISABLE_AGENTS_ROUTE=false
NEXT_PUBLIC_DISABLE_MVP_ROUTE=false
TRUSTED_ORIGINS=http://localhost:3000

# At-rest encryption of agent shared keys. Must be at least 32 chars. generate: openssl rand -base64 32
IRONHUB_KEY_ENCRYPTION_SECRET=

# HMAC secret for private-artifact bearer tokens (required). generate: openssl rand -base64 32
IRONHUB_PRIVATE_ARTIFACT_TOKEN_SECRET=

# Ed25519 private key (base64-encoded PKCS8) used to sign the catalog manifest.
IRONHUB_MANIFEST_SIGNING_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

ILIAD_BASE_URL=
ILIAD_X_API_KEY=
